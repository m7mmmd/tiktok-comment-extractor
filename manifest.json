{
  "manifest_version": 3,
  "name": "TikTok Comment Extractor",
  "version": "1.0.0",
  "description": "Passively captures TikTok comment API responses and exports the full thread (top-level + replies) to CSV and XLSX. Arabic/RTL safe.",
  "permissions": ["scripting", "storage", "activeTab", "downloads", "tabs"],
  "host_permissions": ["*://*.tiktok.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TikTok Comment Extractor",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.tiktok.com/*"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/injected.js"],
      "matches": ["*://*.tiktok.com/*"]
    }
  ]
}
